# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Override files you don't intend to commit
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Sensitive variable files (should be in a separate repo or git-crypt)
*.tfvars
*.tfvars.json

# Ignore any local .tfplan files
*.tfplan

# NOTE: We intentionally do NOT ignore .terraform.lock.hcl in this repo.
# It ensures consistent provider versions across environments.
